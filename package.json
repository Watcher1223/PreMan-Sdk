{
  "name": "preman-sdk",
  "version": "0.1.4",
  "description": "SDK and CLI for turning APIs into hosted MCP servers with scoped consumer tokens.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://preman.live",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Watcher1223/PreMan-Sdk.git"
  },
  "bugs": {
    "url": "https://github.com/Watcher1223/PreMan-Sdk/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "preman": "dist/cli.js",
    "preman-sdk": "dist/cli.js"
  },
  "files": [
    "dist",
    "examples",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test test/*.test.mjs",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "agents",
    "api",
    "sdk",
    "auth",
    "audit",
    "tokens",
    "opentest",
    "preman"
  ],
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "typescript": "^5.8.0",
    "@types/node": "^22.10.0"
  }
}
